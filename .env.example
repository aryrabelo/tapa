# Tapa local configuration. Copy to `.env` and edit. `.env` is gitignored.

# Enable the optional in-app bug-capture overlay (a dev/dogfood tool).
# Leave unset for normal use: when unset the overlay is fully
# dead-code-eliminated from the build (zero added bytes, size budget honored).
VITE_BUGTOPROMPT=1

# AssemblyAI API key for live voice transcription in the overlay. Optional.
# Get one at https://www.assemblyai.com/. Without it the overlay still records
# clicks + DOM snapshots and copies/downloads the AI-ready prompt; only the
# live voice caption is disabled.
VITE_ASSEMBLYAI_API_KEY=
