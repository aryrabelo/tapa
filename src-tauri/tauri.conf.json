{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tapa",
  "mainBinaryName": "Tapa",
  "version": "0.2.1",
  "identifier": "com.aryrabelo.tapa",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tapa",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/aryrabelo/tapa/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_MINISIGN_PUBLIC_KEY"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown",
        "description": "Markdown Document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "dmg": {
        "background": "dmg-background.png",
        "windowSize": { "width": 560, "height": 400 },
        "appPosition": { "x": 160, "y": 160 },
        "applicationFolderPosition": { "x": 400, "y": 160 }
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
